{
  "manifest_version": 3,
  "name": "InternHub Extension",
  "description": "Save internship opportunities and track application status.",
  "version": "0.1.0",
  "action": {
    "default_title": "InternHub",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "activeTab"]
}
